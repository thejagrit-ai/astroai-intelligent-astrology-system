# VITE_GEMINI_API_KEY: Required for client-side Gemini AI API calls.
# Vite exposes only VITE_* variables to browser code.
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional: force a specific Gemini model. If unavailable, app falls back automatically.
VITE_GEMINI_MODEL="gemini-2.5-flash"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
