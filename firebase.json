{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "functions"
  },
  "firestore": [
    {
      "database": "ai-studio-6f758d8e-1eda-4ceb-9cb9-6f0e0694e38f",
      "rules": "firestore.rules"
    }
  ]
}
